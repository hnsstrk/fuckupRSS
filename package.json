{
  "name": "fuckuprss",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "pw:open": "playwright-cli open --config=playwright-cli.json",
    "pw:snapshot": "playwright-cli snapshot",
    "pw:screenshot": "playwright-cli screenshot",
    "pw:close": "playwright-cli close",
    "security:scan": "semgrep scan --config auto src-tauri/src/ src/",
    "security:owasp": "semgrep scan --config p/owasp-top-ten src-tauri/src/ src/",
    "security:audit": "npm audit && cargo audit --file src-tauri/Cargo.lock",
    "format": "prettier --write \"src/**/*.{ts,svelte,js,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,svelte,js,css,json}\"",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "rust:fmt:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "prepare": "husky"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "2.5.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-shell": "^2.0.1",
    "chart.js": "^4.5.1",
    "cytoscape": "^3.33.1",
    "dompurify": "^3.3.1",
    "svelte-i18n": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/cli": "^0.1.0",
    "@playwright/test": "^1.57.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tauri-apps/cli": "^2.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.2.6",
    "@types/cytoscape": "^3.21.9",
    "@types/dompurify": "^3.0.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.2",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.2.7",
    "playwright": "^1.57.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.10.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.55.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.svelte": [
      "eslint --fix",
      "prettier --write --plugin prettier-plugin-svelte"
    ],
    "src/**/*.{css,json}": [
      "prettier --write"
    ]
  }
}
